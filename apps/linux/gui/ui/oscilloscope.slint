import { Theme } from "theme.slint";

// Oscilloscope: RX/TX traces over a fixed window.
// Receives two vectors of normalized samples (0..1, 0 = bottom, 1 = top).
// Renders Path lines via Slint Path element.

export component Oscilloscope inherits Rectangle {
    // Plain SVG-path command strings, computed in Rust (state.rs).
    in property <string> rx_path;
    in property <string> tx_path;
    in property <string> rx_label: "0.0";
    in property <string> tx_label: "0.0";

    border-width: 1px;
    border-color: Theme.hair;
    background: @linear-gradient(180deg, Theme.bg_elev 0%, Theme.bg 100%);

    VerticalLayout {
        // header
        Rectangle {
            height: 44px;
            // bottom hair
            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.hair; }
            HorizontalLayout {
                padding-left: 20px; padding-right: 20px;
                alignment: space-between;
                HorizontalLayout {
                    spacing: 24px;
                    // RX
                    HorizontalLayout {
                        spacing: 10px;
                        Rectangle {
                            width: 18px; height: 2px;
                            background: Theme.rx;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "RX";
                            font-family: Theme.font_display;
                            font-size: 10px;
                            color: Theme.text_dim;
                            letter-spacing: 1.4px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.rx_label;
                            font-family: Theme.font_display;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Mbit/s";
                            font-family: Theme.font_display;
                            font-size: 9px;
                            color: Theme.text_faint;
                            vertical-alignment: center;
                        }
                    }
                    // TX
                    HorizontalLayout {
                        spacing: 10px;
                        Rectangle {
                            width: 18px; height: 2px;
                            background: Theme.tx;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "TX";
                            font-family: Theme.font_display;
                            font-size: 10px;
                            color: Theme.text_dim;
                            letter-spacing: 1.4px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.tx_label;
                            font-family: Theme.font_display;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Mbit/s";
                            font-family: Theme.font_display;
                            font-size: 9px;
                            color: Theme.text_faint;
                            vertical-alignment: center;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "WINDOW";
                        font-family: Theme.font_display;
                        font-size: 10px;
                        color: Theme.text_dim;
                        letter-spacing: 1.4px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "60s";
                        font-family: Theme.font_display;
                        font-size: 13px;
                        color: Theme.text;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // chart canvas
        plot := Rectangle {
            background: transparent;
            preferred-height: 160px;

            // gridlines
            for y in [0.25, 0.5, 0.75] : Rectangle {
                x: 0; y: parent.height * y;
                width: parent.width; height: 1px;
                background: Theme.hair;
                opacity: 0.6;
            }
            for x in [0.25, 0.5, 0.75] : Rectangle {
                x: parent.width * x; y: 0;
                width: 1px; height: parent.height;
                background: Theme.hair;
                opacity: 0.6;
            }

            // axis text
            Text {
                x: 6px; y: 4px;
                text: "250 Mb"; font-family: Theme.font_display; font-size: 9px; color: Theme.text_faint; letter-spacing: 1px;
            }
            Text {
                x: 6px; y: parent.height / 2 - 6px;
                text: "125 Mb"; font-family: Theme.font_display; font-size: 9px; color: Theme.text_faint; letter-spacing: 1px;
            }
            Text {
                x: 6px; y: parent.height - 16px;
                text: "0"; font-family: Theme.font_display; font-size: 9px; color: Theme.text_faint; letter-spacing: 1px;
            }
            Text {
                x: parent.width - 50px; y: parent.height - 16px;
                text: "NOW"; font-family: Theme.font_display; font-size: 9px; color: Theme.text_faint; letter-spacing: 1px;
            }

            // RX trace — uses an SVG-path command string built in Rust.
            Path {
                width: parent.width;
                height: parent.height;
                stroke: Theme.rx;
                stroke-width: 1.5px;
                viewbox-width: 100;
                viewbox-height: 100;
                commands: rx_path;
            }

            // TX trace
            Path {
                width: parent.width;
                height: parent.height;
                stroke: Theme.tx;
                stroke-width: 1.2px;
                viewbox-width: 100;
                viewbox-height: 100;
                commands: tx_path;
            }
        }
    }
}
