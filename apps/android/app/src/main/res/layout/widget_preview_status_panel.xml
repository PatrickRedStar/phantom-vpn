<?xml version="1.0" encoding="utf-8"?>
<!-- Preview: StatusPanel 2×2 (disconnected state). RemoteViews-safe. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wp_bg_10"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <!-- Header: brand + timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="GHOST"
            android:textColor="@color/wp_faint"
            android:textSize="9sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="--:--:--"
            android:textColor="@color/wp_dim"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- State headline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Standby."
        android:textColor="@color/wp_faint"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Server -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="---"
        android:textColor="@color/wp_dim"
        android:textSize="10sp" />

    <!-- Spacer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Separator -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/wp_hair"
        android:importantForAccessibility="no" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="RX"
                android:textColor="@color/wp_faint"
                android:textSize="8sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2014"
                android:textColor="@color/wp_faint"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="TX"
                android:textColor="@color/wp_faint"
                android:textSize="8sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2014"
                android:textColor="@color/wp_faint"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="MUX"
                android:textColor="@color/wp_faint"
                android:textSize="8sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/8"
                android:textColor="@color/wp_bone"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Connect button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/wp_btn_connect">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:text="CONNECT"
            android:textColor="@color/wp_btn_connect_text"
            android:textSize="9sp" />
    </FrameLayout>
</LinearLayout>
