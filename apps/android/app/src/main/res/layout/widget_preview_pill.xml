<?xml version="1.0" encoding="utf-8"?>
<!-- Preview: Pill 4×1 (disconnected state). RemoteViews-safe. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wp_bg_24"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <!-- Status dot -->
    <ImageView
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:importantForAccessibility="no"
        android:src="@drawable/wp_dot" />

    <!-- Label -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:maxLines="1"
        android:text="GhostStream"
        android:textColor="@color/wp_dim"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Separator -->
    <ImageView
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:background="@color/wp_hair"
        android:importantForAccessibility="no" />

    <!-- Speed indicators -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="monospace"
        android:text="↓--"
        android:textColor="@color/wp_faint"
        android:textSize="11sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="monospace"
        android:text="↑--"
        android:textColor="@color/wp_faint"
        android:textSize="11sp" />
</LinearLayout>
