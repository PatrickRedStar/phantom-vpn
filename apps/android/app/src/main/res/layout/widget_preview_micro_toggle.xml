<?xml version="1.0" encoding="utf-8"?>
<!-- Preview: MicroToggle 2×1 (disconnected state). RemoteViews-safe. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wp_bg_10"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp">

    <!-- Status dot -->
    <ImageView
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:importantForAccessibility="no"
        android:src="@drawable/wp_dot" />

    <!-- Server info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="OFFLINE"
            android:textColor="@color/wp_dim"
            android:textSize="9sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="GhostStream"
            android:textColor="@color/wp_bone"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Toggle button -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/wp_btn_circle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="▶"
            android:textColor="@color/wp_btn_connect_text"
            android:textSize="12sp" />
    </FrameLayout>
</LinearLayout>
