# Telegram bot credentials
BOT_TOKEN=123456:placeholder
ADMIN_TELEGRAM_ID=0

# Phantom admin HTTP API (10.7.0.1 is the TUN interface of phantom-server
# on vdsina — container uses network_mode: host so this is directly reachable)
PHANTOM_ADMIN_URL=http://10.7.0.1:8080
PHANTOM_ADMIN_TOKEN=placeholder

# Where roles.json lives inside the container (bind-mounted from ./data)
ROLES_PATH=/data/roles.json
