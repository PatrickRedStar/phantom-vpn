# Telegram bot credentials
BOT_TOKEN=123456:placeholder
ADMIN_TELEGRAM_ID=0

# Phantom admin HTTP API — loopback bot-channel listener on phantom-server.
# В v0.19+ основной admin API на 10.7.0.1:8080 работает по mTLS и доступен
# только клиентам VPN. Бот ходит через отдельный plain-HTTP+Bearer listener
# на 127.0.0.1:8081 (host network в docker-compose.yml).
PHANTOM_ADMIN_URL=http://127.0.0.1:8081
PHANTOM_ADMIN_TOKEN=placeholder
