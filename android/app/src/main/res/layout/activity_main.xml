<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PhantomVPN"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- ── Строка подключения ───────────────────────────── -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Строка подключения" android:textSize="13sp"
            android:textStyle="bold" android:textColor="#333"
            android:layout_marginBottom="4dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Получите в keys.py → пункт 5, вставьте сюда и нажмите Импортировать"
            android:textSize="11sp" android:textColor="#888"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/et_conn_str"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="eyJ2IjoxLCJhZGRyIjoiOD…"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="2" android:maxLines="5"
            android:scrollbars="vertical"
            android:fontFamily="monospace" android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <Button android:id="@+id/btn_import"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Импортировать"
            android:layout_marginBottom="20dp" />

        <!-- divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDD" android:layout_marginBottom="16dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Ручная настройка" android:textSize="13sp"
            android:textStyle="bold" android:textColor="#333"
            android:layout_marginBottom="12dp" />

        <!-- Server address -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Адрес сервера (ip:port)" android:textSize="12sp" android:textColor="#666" />
        <EditText android:id="@+id/et_server_addr"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="89.110.109.128:8443" android:inputType="textUri"
            android:singleLine="true" android:layout_marginBottom="12dp" />

        <!-- SNI -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Имя сервера (SNI)" android:textSize="12sp" android:textColor="#666" />
        <EditText android:id="@+id/et_server_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="nl2.bikini-bottom.com" android:inputType="textUri"
            android:singleLine="true" android:layout_marginBottom="12dp" />

        <!-- Insecure -->
        <CheckBox android:id="@+id/cb_insecure"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Пропустить проверку TLS сертификата (небезопасно)"
            android:layout_marginBottom="12dp" />

        <!-- Cert path -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Путь к сертификату клиента (.crt)" android:textSize="12sp" android:textColor="#666" />
        <EditText android:id="@+id/et_cert_path"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="/sdcard/Android/data/com.phantom.vpn/files/client.crt"
            android:inputType="textUri" android:singleLine="true"
            android:layout_marginBottom="8dp" />

        <!-- Key path -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Путь к приватному ключу (.key)" android:textSize="12sp" android:textColor="#666" />
        <EditText android:id="@+id/et_key_path"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="/sdcard/Android/data/com.phantom.vpn/files/client.key"
            android:inputType="textUri" android:singleLine="true"
            android:layout_marginBottom="20dp" />

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_connect"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Подключить" />
            <Button android:id="@+id/btn_disconnect"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Отключить"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Status -->
        <TextView android:id="@+id/tv_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Не подключено" android:textSize="14sp" android:textColor="#333" />

    </LinearLayout>
</ScrollView>
